// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Tenant – represents a single mechanic shop subscription.
// All other models cascade from tenantId so data is fully isolated.
// ---------------------------------------------------------------------------
model Tenant {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  // Stripe Billing (Issue #29)
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  // QuickBooks Online OAuth (Issue #32) — tokens stored server-side only
  qboRealmId         String?
  qboAccessToken     String?
  qboRefreshToken    String?
  // Google Business integration (Issue #33)
  googlePlaceId      String?
  reviewLink         String?
  // Mechanic's forwarding cell phone for Twilio voice (Issue #34)
  ownerPhone         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  clients           Client[]
  vehicles          Vehicle[]
  workOrders        WorkOrder[]
  outboundCampaigns OutboundCampaign[]
  consumables       Consumable[]
  warranties        Warranty[]
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

// ---------------------------------------------------------------------------
// Client – vehicle owner / customer of a specific tenant.
// ---------------------------------------------------------------------------
model Client {
  id                String   @id @default(cuid())
  tenantId          String
  firstName         String
  lastName          String
  email             String?
  phone             String
  zipCode           String?  // ZIP code used for drive-time padding calculations
  isCommercialFleet Boolean  @default(false) // true for small-business fleet accounts
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]
  workOrders WorkOrder[]
  outboundCampaigns OutboundCampaign[]

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// GlobalVehicle – shared library of vehicle makes/models with OEM maintenance
// schedules. Not tenant-specific; a single row covers all year-range variants.
// ---------------------------------------------------------------------------
model GlobalVehicle {
  id                      String   @id @default(cuid())
  make                    String
  model                   String
  yearStart               Int
  yearEnd                 Int?
  // JSON array of MaintenanceItem: { service, intervalMiles?, atMileage? }
  maintenanceScheduleJson Json     @default("[]")
  // Fluid capacity & OEM oil weight (Issue #41)
  oilCapacityQts          Float?   // Engine oil capacity in US quarts
  oilWeightOem            String?  // e.g. "0W-20 Full Synthetic"
  // Array of trim/engine combos when VIN returns multiple possibilities
  submodelOptionsJson     Json     @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  vehicles Vehicle[]

  @@unique([make, model, yearStart])
  @@index([make, model])
}

// ---------------------------------------------------------------------------
// Vehicle – belongs to a Client and a Tenant (TenantVehicles).
// Optionally linked to a GlobalVehicle row for OEM maintenance data.
// ---------------------------------------------------------------------------
model Vehicle {
  id              String   @id @default(cuid())
  tenantId        String
  clientId        String
  globalVehicleId String?
  make            String
  model           String
  year            Int
  vin             String?
  plate           String?
  color           String?
  mileageIn       Int?     // Current odometer reading entered by shop
  oilType         String?  // e.g. "5W-30 Full Synthetic"
  tireSize        String?  // e.g. "225/55R17"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  globalVehicle GlobalVehicle? @relation(fields: [globalVehicleId], references: [id])
  workOrders    WorkOrder[]

  @@index([tenantId])
  @@index([clientId])
}

// ---------------------------------------------------------------------------
// WorkOrder – the core operational record for a job.
// ---------------------------------------------------------------------------
model WorkOrder {
  id            String          @id @default(cuid())
  tenantId      String
  clientId      String
  vehicleId     String
  status        WorkOrderStatus @default(INTAKE)
  title         String
  description   String
  notes         String?
  laborCents    Int             @default(0)
  partsCents    Int             @default(0)
  // Wholesale cost of parts (COGS). When null, a 55% markup ratio is assumed.
  partsCostCents        Int?
  // When true, parts are billed at cost; liability flag shown on Work Order.
  customerSuppliedParts Boolean  @default(false)
  // Change-order delta parts (SelectedPart[]) added after initial approval.
  deltaPartsJson        Json?
  // Token for client to review & sign the delta change order.
  deltaApprovalToken    String?  @unique
  // True once the mandatory pre-inspection walkaround is completed.
  preCheckComplete      Boolean  @default(false)
  approvalToken String?         @unique
  scheduledAt   DateTime?       // Calendar appointment timestamp
  closedAt      DateTime?
  paymentMethod String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
}

enum WorkOrderStatus {
  REQUESTED        // Customer self-submitted via intake link; awaiting shop review
  INTAKE
  ACTIVE
  PENDING_APPROVAL
  BLOCKED_WAITING_APPROVAL // Mechanic awaiting client sign-off on a change order
  COMPLETE
  INVOICED
  PAID
}

// ---------------------------------------------------------------------------
// OutboundCampaign – AI-generated or blast marketing messages sent via SMS.
// ---------------------------------------------------------------------------
model OutboundCampaign {
  id           String                 @id @default(cuid())
  tenantId     String
  clientId     String?
  phoneNumber  String?
  message      String
  campaignType String                 // "AI_GENERATED" | "BLAST"
  audience     String?                // Target audience label for blast campaigns
  status       OutboundCampaignStatus @default(QUEUED)
  sentAt       DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

enum OutboundCampaignStatus {
  QUEUED
  SENT
  DISCARDED
}

// ---------------------------------------------------------------------------
// Consumable – tracks bulk shop supplies (oil, brake cleaner, rags, etc.).
// Stock is automatically deducted when a WorkOrder is marked PAID based on
// the vehicle's oil capacity from GlobalLexicon.
// ---------------------------------------------------------------------------
model Consumable {
  id                String   @id @default(cuid())
  tenantId          String
  name              String   // e.g. "5W-30 Synthetic", "Brake Cleaner"
  unit              String   // e.g. "Quart", "Can", "Sheet"
  currentStock      Float    @default(0)  // How many units remain
  lowStockThreshold Float    @default(5)  // Glow-red warning below this level
  costPerUnitCents  Int      @default(0)  // Wholesale cost per unit in cents
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Warranty — tracks parts warranty windows per work-order line item (Issue #36).
// ---------------------------------------------------------------------------
model Warranty {
  id              String   @id @default(cuid())
  tenantId        String
  workOrderId     String
  clientId        String?
  partName        String
  partNumber      String?
  supplier        String?
  installedAt     DateTime @default(now())
  warrantyMonths  Int      @default(12)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workOrderId])
}
