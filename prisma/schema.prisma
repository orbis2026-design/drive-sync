generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  slug                 String             @unique
  email                String?            @unique
  ownerUserId          String?            @map("owner_user_id") @db.Uuid
  featuresJson         Json               @default("{\"fleet\": true, \"inventory\": true, \"marketing\": true}") @map("features_json")
  googlePlaceId        String?            @map("google_place_id")
  reviewLink           String?            @map("review_link")
  taxMatrixJson        Json               @default("{\"labor_tax_rate\": 0.00, \"parts_tax_rate\": 0.085, \"environmental_fee_flat\": 5.00, \"environmental_fee_percentage\": 0.00}") @map("tax_matrix_json")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  subscriptionStatus   SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  qboRealmId           String?            @map("qbo_realm_id")
  qboAccessToken       String?            @map("qbo_access_token")
  qboRefreshToken      String?            @map("qbo_refresh_token")
  onboardingComplete   Boolean            @default(false) @map("onboarding_complete")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  ownerPhone           String?            @map("owner_phone")
  shopZipCode          String?            @map("shop_zip_code")
  partsTaxRate         Decimal            @default(0.085) @map("parts_tax_rate") @db.Decimal(6, 4)
  laborTaxRate         Decimal            @default(0.0) @map("labor_tax_rate") @db.Decimal(6, 4)
  autoRetentionEnabled Boolean            @default(true) @map("auto_retention_enabled")

  @@map("tenants")
}

model Client {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  email             String?
  phone             String
  zipCode           String?  @map("zip_code")
  isCommercialFleet Boolean  @default(false) @map("is_commercial_fleet")
  clientUserId      String?  @map("client_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  opted_out_sms     Boolean  @default(false) @map("opted_out_sms")

  @@index([tenantId], map: "idx_clients_tenant_id")
  @@map("clients")
}

model GlobalVehicle {
  id                      String   @id @default(uuid()) @db.Uuid
  yearStart               Int      @map("year")
  make                    String
  model                   String
  vin                     String?  @unique
  engine                  String?
  trim                    String?
  maintenanceScheduleJson Json     @default("[]") @map("maintenance_schedule_json")
  knownFaultsJson         Json     @default("[]") @map("known_faults_json")
  oilCapacityQts          Float?   @map("oil_capacity_qts")
  oilWeightOem            String?  @map("oil_weight_oem")
  submodelOptionsJson     Json     @default("[]") @map("submodel_options_json")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  yearEnd                 Int?

  @@unique([yearStart, make, model, engine], map: "uq_global_vehicle")
  @@index([make, model], map: "idx_global_vehicles_make_model")
  @@map("global_vehicles")
}

model Vehicle {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  globalVehicleId String?  @map("global_vehicle_id") @db.Uuid
  plate           String?  @map("license_plate")
  vin             String?  @unique
  mileageIn       Int?     @map("mileage")
  color           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  make            String?
  model           String?
  year            Int?
  oilType         String?  @map("oil_type")
  tireSize        String?  @map("tire_size")

  @@index([clientId], map: "idx_tenant_vehicles_client_id")
  @@index([tenantId], map: "idx_tenant_vehicles_tenant_id")
  @@map("tenant_vehicles")
}

model WorkOrder {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String          @map("tenant_id") @db.Uuid
  vehicleId             String          @map("tenant_vehicle_id") @db.Uuid
  status                WorkOrderStatus @default(INTAKE)
  title                 String
  description           String
  notes                 String?
  mileage_at_intake     Int?
  laborCents            Int             @default(0) @map("labor_cents")
  partsCents            Int             @default(0) @map("parts_cents")
  partsCostCents        Int?            @map("parts_cost_cents")
  scheduledAt           DateTime?       @map("scheduled_at") @db.Timestamptz(6)
  intake_photo_url      String?
  inspection_json       Json?
  parts_json            Json?
  customerSuppliedParts Boolean         @default(false) @map("customer_supplied_parts")
  deltaPartsJson        Json?           @map("delta_parts_json")
  deltaApprovalToken    String?         @unique @map("delta_approval_token") @db.Uuid
  preCheckComplete      Boolean         @default(false) @map("pre_check_complete")
  approvalToken         String?         @unique @map("approval_token") @db.Uuid
  closedAt              DateTime?       @map("closed_at") @db.Timestamptz(6)
  paymentMethod         String?         @map("payment_method")
  versionHash           String          @default(dbgenerated("gen_random_uuid()")) @map("version_hash") @db.Uuid
  isLocked              Boolean         @default(false) @map("is_locked")
  laborJson             Json?           @map("labor_json")
  isDiagnostic          Boolean         @default(false) @map("is_diagnostic")
  diagnosticFeeCents    Int             @default(0) @map("diagnostic_fee_cents")
  rollDiagnosticFee     Boolean         @default(false) @map("roll_diagnostic_fee")
  assignedTechId        String?         @map("assigned_tech_id") @db.Uuid
  hasDamageFlag         Boolean         @default(false) @map("has_damage_flag")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  checklists_json       Json?

  @@index([tenantId, scheduledAt], map: "idx_work_orders_scheduled_at", where: raw("(scheduled_at IS NOT NULL)"))
  @@index([tenantId, status], map: "idx_work_orders_status")
  @@index([tenantId], map: "idx_work_orders_tenant_id")
  @@map("work_orders")
}

model OutboundCampaign {
  id              String                 @id @default(uuid()) @db.Uuid
  tenantId        String                 @map("tenant_id") @db.Uuid
  tenantVehicleId String                 @map("tenant_vehicle_id") @db.Uuid
  clientId        String                 @map("client_id") @db.Uuid
  phoneNumber     String                 @map("to_phone")
  message         String                 @map("message_body")
  campaignType    String                 @map("service_name")
  milesUntilDue   Int?                   @map("miles_until_due")
  daysUntilDue    Int?                   @map("days_until_due")
  status          OutboundCampaignStatus @default(QUEUED)
  sentAt          DateTime?              @map("sent_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  audience        String?                @ignore

  @@index([tenantId], map: "idx_outbound_campaigns_tenant_id")
  @@map("outbound_campaigns")
}

model Consumable {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  name              String
  unit              String
  currentStock      Float    @default(0) @map("current_stock")
  lowStockThreshold Float    @default(5) @map("low_stock_threshold")
  costPerUnitCents  Int      @default(0) @map("cost_per_unit_cents")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId], map: "idx_consumables_tenant_id")
  @@map("consumables")
}

model Part {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String                 @map("tenant_id") @db.Uuid
  partNumber            String?                @map("part_number")
  name                  String
  brand                 String?
  category              String?
  subcategory           String?
  unit                  String?
  barcode               String?
  defaultMarkupPercent  Decimal?               @map("default_markup_percent") @db.Decimal(5, 2)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  stockLevels           StockLevel[]
  inventoryTransactions InventoryTransaction[]
  purchaseOrderLines    PurchaseOrderLine[]
  packageItems          PackageItem[]

  @@index([tenantId], map: "idx_parts_tenant_id")
  @@unique([tenantId, partNumber], map: "uq_parts_tenant_part_number")
  @@map("parts")
}

model InventoryLocation {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String                 @map("tenant_id") @db.Uuid
  name                  String
  code                  String?
  kind                  String                 @default("PRIMARY")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  stockLevels           StockLevel[]
  inventoryTransactions InventoryTransaction[]

  @@index([tenantId], map: "idx_inventory_locations_tenant_id")
  @@map("inventory_locations")
}

model StockLevel {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  partId            String   @map("part_id") @db.Uuid
  locationId        String   @map("location_id") @db.Uuid
  quantity          Decimal  @default(0) @map("quantity") @db.Decimal(12, 2)
  lowStockThreshold Decimal  @default(0) @map("low_stock_threshold") @db.Decimal(12, 2)
  costPerUnitCents  Int      @default(0) @map("cost_per_unit_cents")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  part              Part              @relation(fields: [partId], references: [id])
  location          InventoryLocation @relation(fields: [locationId], references: [id])

  @@index([tenantId, locationId], map: "idx_stock_levels_tenant_location")
  @@unique([tenantId, partId, locationId], map: "uq_stock_levels_tenant_part_location")
  @@map("stock_levels")
}

model InventoryTransaction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  partId           String   @map("part_id") @db.Uuid
  locationId       String   @map("location_id") @db.Uuid
  quantity         Decimal  @map("quantity") @db.Decimal(12, 2)
  direction        String   @map("direction")
  reason           String   @map("reason")
  costPerUnitCents Int?     @map("cost_per_unit_cents")
  metadata         Json?    @map("metadata_json")
  occurredAt       DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  part             Part              @relation(fields: [partId], references: [id])
  location         InventoryLocation @relation(fields: [locationId], references: [id])

  @@index([tenantId, occurredAt], map: "idx_inventory_transactions_tenant_occurred_at")
  @@map("inventory_transactions")
}

model Vendor {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  contactName String?  @map("contact_name")
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  purchaseOrders PurchaseOrder[]

  @@index([tenantId], map: "idx_vendors_tenant_id")
  @@unique([tenantId, name], map: "uq_vendors_tenant_name")
  @@map("vendors")
}

model PurchaseOrder {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  vendorId         String?            @map("vendor_id") @db.Uuid
  supplierPoNumber String?            @map("supplier_po_number")
  status           String             @default("CONFIRMED")
  deliveryType     String             @map("delivery_type")
  estimatedReadyAt DateTime?          @map("estimated_ready_at") @db.Timestamptz(6)
  receivedAt       DateTime?          @map("received_at") @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  vendor           Vendor?            @relation(fields: [vendorId], references: [id])
  lines            PurchaseOrderLine[]

  @@index([tenantId], map: "idx_purchase_orders_tenant_id")
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  purchaseOrderId    String        @map("purchase_order_id") @db.Uuid
  partId             String?       @map("part_id") @db.Uuid
  partNumber         String        @map("part_number")
  description        String        @map("description")
  qty                Decimal       @map("qty") @db.Decimal(12, 2)
  wholesalePriceCents Int          @map("wholesale_price_cents")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  purchaseOrder      PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  part               Part?         @relation(fields: [partId], references: [id])

  @@index([tenantId, purchaseOrderId], map: "idx_purchase_order_lines_tenant_po")
  @@map("purchase_order_lines")
}

model LaborService {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String
  description String?
  laborType   String        @map("labor_type")
  defaultHours Decimal      @map("default_hours") @db.Decimal(5, 2)
  rateCents   Int?          @map("rate_cents")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  packageItems PackageItem[]

  @@index([tenantId], map: "idx_labor_services_tenant_id")
  @@map("labor_services")
}

model Package {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  items       PackageItem[]

  @@index([tenantId], map: "idx_packages_tenant_id")
  @@map("packages")
}

model PackageItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  packageId      String       @map("package_id") @db.Uuid
  kind           String       @map("kind")
  partId         String?      @map("part_id") @db.Uuid
  laborServiceId String?      @map("labor_service_id") @db.Uuid
  quantity       Decimal      @map("quantity") @db.Decimal(12, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  package        Package      @relation(fields: [packageId], references: [id])
  part           Part?        @relation(fields: [partId], references: [id])
  laborService   LaborService? @relation(fields: [laborServiceId], references: [id])

  @@index([tenantId, packageId], map: "idx_package_items_tenant_package")
  @@map("package_items")
}

model Warranty {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  workOrderId    String    @map("work_order_id")
  clientId       String?   @map("client_id") @db.Uuid
  partName       String    @map("part_name")
  partNumber     String?   @map("part_number")
  supplier       String?
  installedAt    DateTime  @default(now()) @map("installed_at") @db.Timestamptz(6)
  warrantyMonths Int       @default(12) @map("warranty_months")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([workOrderId])
  @@map("warranties")
}

model UserRole {
  userId    String       @id @map("user_id") @db.Uuid
  role      UserRoleType @default(SHOP_OWNER)
  tenantId  String?      @map("tenant_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("user_roles")
}

model PromoCode {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique
  discountPercent Int      @default(0) @map("discount_percent")
  applicableTier  String   @default("SOLO_TECH") @map("applicable_tier")
  maxUses         Int      @default(1) @map("max_uses")
  uses            Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  durationMonths  Int?

  @@map("promo_codes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model expenses {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  amount            Decimal  @db.Decimal(10, 2)
  vendor            String
  category          String   @default("General")
  receipt_image_url String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([tenant_id, created_at(sort: Desc)], map: "expenses_tenant_id_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mechanic_settings {
  id               BigInt   @id @default(autoincrement())
  user_id          String   @unique @db.Uuid
  labor_rate_cents Int      @default(12000)
  parts_tax_rate   Decimal  @default(0.0875) @db.Decimal(6, 4)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  client_id   String?  @db.Uuid
  body        String
  direction   String
  from_number String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([client_id, created_at(sort: Desc)], map: "messages_client_id_idx")
  @@index([tenant_id, created_at(sort: Desc)], map: "messages_tenant_id_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model shop_messages {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  user_id    String   @db.Uuid
  channel    String   @default("#general")
  body       String
  is_ai      Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([tenant_id, channel, created_at(sort: Desc)], map: "idx_shop_messages_tenant_channel")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_passkeys {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  credential_id  String   @unique
  public_key_der String
  device_label   String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED

  @@map("subscription_status")
}

enum WorkOrderStatus {
  REQUESTED
  INTAKE
  ACTIVE
  PENDING_APPROVAL
  BLOCKED_WAITING_APPROVAL
  COMPLETE
  INVOICED
  PAID
  BATCHED_PENDING_PAYMENT
  CANCELLED

  @@map("work_order_status")
}

enum OutboundCampaignStatus {
  QUEUED
  SENT
  FAILED
  DISCARDED

  @@map("outbound_campaign_status")
}

enum UserRoleType {
  SHOP_OWNER
  FIELD_TECH
  FLEET_CLIENT

  @@map("user_role")
}
